{
  "name": "webflow-dashboard-svelte",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "pnpm build && node scripts/run-wrangler.mjs pages deploy .svelte-kit/cloudflare --project-name=webflow-dashboard --commit-dirty=true",
    "deploy:preview": "pnpm build && node scripts/run-wrangler.mjs pages deploy .svelte-kit/cloudflare --project-name=webflow-dashboard --branch=preview --commit-dirty=true"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@sveltejs/adapter-cloudflare": "^4.8.0",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/uuid": "^10.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.16",
    "wrangler": "^4.103.0"
  },
  "dependencies": {
    "@create-something/canon": "workspace:^",
    "@create-something/webflow-dashboard-core": "workspace:*",
    "airtable": "^0.12.2",
    "isomorphic-dompurify": "^2.35.0",
    "lucide-svelte": "^0.454.0",
    "uuid": "^11.0.3"
  },
  "type": "module"
}
