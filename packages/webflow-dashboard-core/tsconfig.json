{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["@cloudflare/workers-types", "node"],
    "declaration": false,
    "noEmit": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@create-something/webflow-dashboard-core": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts"]
}
